<!-- views/verify-otp.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex items-center justify-center h-screen">

    <div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-slate-800">Verify Email</h1>
            <p class="text-slate-500 mt-2">We have sent a 6-digit code to your email address <span class="font-semibold text-blue-600"><%= email %></span> </p>
        </div>

        <!-- OTP FORM -->
        <form action="/verify-otp" method="post" class="space-y-6">
            
            <!-- Hidden Input: Email ko wapas server par bhejne ke liye -->
            <input type="hidden" name="email" value="<%= email %>">

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Enter 6-Digit OTP</label>
                <input 
                    type="text" 
                    name="otp" 
                    maxlength="6" 
                    required 
                    placeholder="000000"
                    class="w-full px-4 py-4 text-center text-2xl tracking-[1rem] font-bold border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                >
            </div>

            <button 
                type="submit" 
                class="w-full bg-blue-600 text-white font-semibold py-3 rounded-lg hover:bg-blue-700 shadow-md shadow-blue-200 transition-all duration-300 active:scale-95"
            >
                Verify & Register
            </button>
        </form>
        <form action="/resend-otp" method="post" class="mt-4 text-center">
    <input type="hidden" name="email" value="<%= email %>">
    <button type="submit" class="text-blue-600 text-sm hover:underline">Resend OTP</button>
</form>

        <div class="mt-8 text-center">
            <p class="text-sm text-slate-500">
                code not found? 
                <a href="/register" class="text-blue-600 font-medium hover:underline">try again</a>
            </p>
        </div>
    </div>

</body>
</html>