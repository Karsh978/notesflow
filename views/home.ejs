<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NoteFlow | Premium Note Taking</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); }
        .note-card:hover { transform: translateY(-5px); transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 glass border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-200">
                    <i class="fa-solid fa-bolt text-white"></i>
                </div>
                <span class="text-2xl font-bold tracking-tight bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">NoteFlow</span>
            </div>
            
            <div class="hidden md:flex items-center gap-8 font-medium text-slate-600">
                <a href="#features" class="hover:text-indigo-600 transition-colors">Features</a>
                <a href="#notes" class="hover:text-indigo-600 transition-colors">My Notes</a>
                <a href="/login" class="bg-indigo-600 text-white px-5 py-2.5 rounded-full hover:bg-indigo-700 transition-all shadow-md">
                    <i class="fa-solid fa-plus mr-2"></i> New Note
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="relative overflow-hidden pt-16 pb-20 lg:pt-24">
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center max-w-3xl mx-auto">
                <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 mb-6 leading-tight">
                    Capture your thoughts, <span class="text-indigo-600">effortlessly.</span>
                </h1>
                <p class="text-lg text-slate-600 mb-10 leading-relaxed">
                    NoteFlow is the cleanest way to organize your life. Write, manage, and find your notes in seconds with our advanced workspace.
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="/login" class="px-8 py-4 bg-indigo-600 text-white rounded-2xl font-semibold text-lg hover:shadow-xl hover:bg-indigo-700 transition-all">Get Started Free</a>
                    <a href="#features" class="px-8 py-4 bg-white border border-slate-200 text-slate-700 rounded-2xl font-semibold text-lg hover:bg-slate-50 transition-all">Explore Features</a>
                </div>
            </div>
        </div>
        <!-- Decorative Background Gradient -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-indigo-100 rounded-full blur-[120px] opacity-50"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-100 rounded-full blur-[120px] opacity-50"></div>
        </div>
    </header>

    <!-- Features Section -->
    <section id="features" class="py-24 bg-white border-y border-slate-100">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold mb-4">Why NoteFlow?</h2>
                <div class="w-20 h-1.5 bg-indigo-600 mx-auto rounded-full"></div>
            </div>
            
            <div class="grid md:grid-cols-3 gap-12">
                <!-- Feature 1 -->
                <div class="group">
                    <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                        <i class="fa-solid fa-wand-magic-sparkles text-xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Minimal Design</h3>
                    <p class="text-slate-600 leading-relaxed">Distraction-free interface designed to help you focus on your writing and creativity.</p>
                </div>
                <!-- Feature 2 -->
                <div class="group">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                        <i class="fa-solid fa-shield-halved text-xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Secure & Private</h3>
                    <p class="text-slate-600 leading-relaxed">Your notes are stored securely, ensuring that your personal thoughts stay yours alone.</p>
                </div>
                <!-- Feature 3 -->
                <div class="group">
                    <div class="w-14 h-14 bg-violet-50 text-violet-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-violet-600 group-hover:text-white transition-all duration-300">
                        <i class="fa-solid fa-bolt-lightning text-xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Lightning Fast</h3>
                    <p class="text-slate-600 leading-relaxed">Instant search and zero lag. Find any note in your collection in the blink of an eye.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Notes Section -->
    <section id="notes" class="max-w-7xl mx-auto px-6 py-20">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h2 class="text-3xl font-bold text-slate-900">Your Workspace</h2>
                <p class="text-slate-500 mt-1">Manage your collection of <%= notes.length %> notes</p>
            </div>
            <div class="flex gap-4">
                <div class="relative hidden sm:block">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" placeholder="Quick search..." class="pl-11 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none w-64 transition-all">
                </div>
            </div>
        </div>

        <!-- Notes Grid -->
        <% if (notes.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% notes.forEach(note => { %>
                    <div class="note-card bg-white p-8 rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl transition-all flex flex-col h-full">
                        <div class="flex-1">
                            <div class="flex items-start justify-between mb-4">
                                <h3 class="text-xl font-bold text-slate-800 leading-snug"><%= note.title %></h3>
                                <div class="bg-indigo-50 text-indigo-600 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">Note</div>
                            </div>
                            <p class="text-slate-600 text-sm leading-relaxed mb-6 line-clamp-4">
                                <%= note.body %>
                            </p>
                        </div>

                        <div class="pt-6 border-t border-slate-50 flex items-center justify-between">
                            <span class="text-xs font-medium text-slate-400">
                                <i class="fa-regular fa-calendar mr-1"></i> <%= note.createdAt.toLocaleDateString() %>
                            </span>
                            <div class="flex gap-2">
                                <a href="/edit/<%= note.id %>" class="w-9 h-9 flex items-center justify-center rounded-full bg-slate-50 text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">
                                    <i class="fa-solid fa-pen text-sm"></i>
                                </a>
                                <form action="/delete/<%= note.id %>?_method=DELETE" method="POST">
                                    <button class="w-9 h-9 flex items-center justify-center rounded-full bg-slate-50 text-slate-600 hover:bg-red-50 hover:text-red-600 transition-colors">
                                        <i class="fa-solid fa-trash-can text-sm"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="text-center py-20 bg-slate-100/50 rounded-[40px] border-2 border-dashed border-slate-200">
                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
                    <i class="fa-solid fa-pen-nib text-3xl text-slate-300"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 mb-2">Your canvas is empty</h3>
                <p class="text-slate-500 mb-8">Click the button below to create your very first note.</p>
                <a href="/add-note" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white rounded-xl font-semibold hover:bg-indigo-700 transition-all">
                    <i class="fa-solid fa-plus"></i> Create Now
                </a>
            </div>
        <% } %>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-16">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-4 gap-12 mb-12">
                <div class="col-span-1 md:col-span-1">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-bolt text-white text-sm"></i>
                        </div>
                        <span class="text-xl font-bold text-white">NoteFlow</span>
                    </div>
                    <p class="text-sm leading-relaxed">The best way to manage your daily thoughts and professional projects in one place.</p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6">Product</h4>
                    <ul class="space-y-4 text-sm">
                        <li><a href="#" class="hover:text-indigo-400 transition-colors">Features</a></li>
                        <li><a href="#" class="hover:text-indigo-400 transition-colors">Templates</a></li>
                        <li><a href="#" class="hover:text-indigo-400 transition-colors">Integrations</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6">Support</h4>
                    <ul class="space-y-4 text-sm">
                        <li><a href="#" class="hover:text-indigo-400 transition-colors">Help Center</a></li>
                        <li><a href="#" class="hover:text-indigo-400 transition-colors">API Docs</a></li>
                        <li><a href="#" class="hover:text-indigo-400 transition-colors">Community</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6">Stay Connected</h4>
                    <div class="flex gap-4">
                        <a href="https://x.com/JivanKarsh?t=h29fcs7k_w1XKcMFu31kfg&s=09" class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition-all"><i class="fa-brands fa-twitter"></i></a>
                        <a href="https://github.com/dashboard" class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition-all"><i class="fa-brands fa-github"></i></a>
                        <a href="www.linkedin.com/in/jiwan-karsh-b03084345" class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition-all"><i class="fa-brands fa-discord"></i></a>
                    </div>
                </div>
            </div>
            <div class="pt-8 border-t border-slate-800 text-center text-xs">
                <p>&copy; 2026 NoteFlow App. All rights reserved. Designed for g-one.</p>
            </div>
        </div>
    </footer>

    <!-- Mobile Action Button -->
    <a href="/add-note" class="md:hidden fixed bottom-8 right-8 w-16 h-16 bg-indigo-600 text-white rounded-2xl shadow-2xl flex items-center justify-center text-2xl z-50">
        <i class="fa-solid fa-plus"></i>
    </a>

</body>
</html>