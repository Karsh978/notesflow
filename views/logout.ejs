<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logout | StickyNotes</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4">

  <div class="bg-white p-8 rounded-2xl shadow-xl shadow-slate-200 w-full max-w-sm border border-slate-100 text-center">
    
    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-20 h-20 bg-red-50 rounded-full mb-6 text-4xl">
      👋
    </div>

    <!-- Content -->
    <h1 class="text-2xl font-bold text-slate-800">Signing Out?</h1>
    <p class="text-slate-500 mt-2 mb-8 leading-relaxed">
    are you sure to logout? your all notes is safe.
    </p>

    <!-- Form & Buttons -->
    <div class="flex flex-col gap-3">
        <!-- Actual Logout Form -->
        <form action="/logout" method="GET">
            <button type="submit" 
              class="w-full bg-red-600 text-white font-semibold py-3.5 rounded-xl hover:bg-red-700 shadow-lg shadow-red-100 transition-all active:scale-[0.98]">
              Yes, Logout
            </button>
        </form>

        <!-- Cancel / Go Back -->
        <a href="/notes" 
          class="w-full bg-slate-100 text-slate-700 font-semibold py-3.5 rounded-xl hover:bg-slate-200 transition-all text-sm">
          No, Stay Logged In
        </a>
    </div>

    <p class="mt-8 text-xs text-slate-400">
      StickyNotes - Organizing your thoughts.
    </p>
  </div>

</body>
</html>