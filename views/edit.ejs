<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Note | StickyNotes</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    textarea { resize: none; }
  </style>
</head>
<body class="bg-slate-50 min-h-screen">

  <!-- Navbar -->
  <nav class="bg-white border-b border-slate-200 sticky top-0 z-10">
    <div class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <a href="/notes" class="text-slate-400 hover:text-slate-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
        <span class="font-bold text-slate-800">Edit Note</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-xs font-semibold text-slate-400 bg-slate-100 px-2 py-1 rounded">Editing Mode</span>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 py-10">
    
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-amber-50/30">
        <h2 class="text-lg font-bold text-slate-700">Modify Your Note</h2>
        <span class="text-[10px] font-bold text-amber-600 uppercase tracking-widest">Changes will be saved</span>
      </div>

      <!-- User's Original Action Path kept: /update/:id -->
      <form action="/update/<%= note._id %>" method="POST" class="p-8 space-y-6">
        
        <!-- Title Input -->
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 ml-1">Update Title</label>
          <input 
            type="text" 
            name="title" 
            value="<%= note.title %>"
            placeholder="Note title..." 
            required
            class="w-full text-2xl font-bold text-slate-800 placeholder:text-slate-300 border-none focus:ring-0 p-0"
          >
        </div>

        <hr class="border-slate-100">

        <!-- Content Area -->
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 ml-1">Update Content</label>
          <textarea 
            name="content" 
            placeholder="Modify your content here..." 
            required
            class="w-full min-h-[350px] text-lg text-slate-600 placeholder:text-slate-300 border-none focus:ring-0 p-0 leading-relaxed"
          ><%= note.content %></textarea>
        </div>

        <!-- Action Buttons -->
        <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-4">
          <a href="/notes" class="px-6 py-2.5 text-slate-500 font-semibold hover:text-slate-700 transition-colors">
            Discard Changes
          </a>
          <button type="submit" 
            class="bg-blue-600 text-white px-8 py-2.5 rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-100 transition-all active:scale-95">
            Save Changes
          </a>
        </div>

      </form>
    </div>

    <!-- Footer Info -->
    <div class="mt-6 text-center">
        <p class="text-xs text-slate-400 italic">Editing: ID #<%= note._id %></p>
    </div>

  </main>

</body>
</html>